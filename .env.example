# Copy this file to .env.local and fill in your real values.
# .env.local is git-ignored (.env*.local) — real secrets live ONLY there (and in your
# host's env vars, e.g. Vercel). This file must contain PLACEHOLDERS ONLY:
# never commit real keys, hashes, or passwords.

# --- Supabase (required for the database-backed content / admin panel) ---
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
# Publishable (anon) key — browser-safe, read-only under the hardened RLS:
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_your-anon-key-here
# Secret (service_role) key — SERVER ONLY, used for all writes. Never NEXT_PUBLIC_:
SUPABASE_SECRET_KEY=sb_secret_your-secret-key-here

# --- Admin panel auth (required to log in at /admin) ---
# Either set a plaintext password (simplest)...
ADMIN_PASSWORD=your-strong-admin-password
# ...or a bcrypt hash (preferred). Generate with:
#   node -e "console.log(require('bcryptjs').hashSync('your-password', 10))"
# ADMIN_PASSWORD_HASH=

# Secret used to sign admin session cookies. Set a long random value in production:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ADMIN_SECRET=your-64-char-random-hex-secret

# --- Contact form email via Resend (optional) ---
# Without these, contact submissions are logged in development instead of emailed.
RESEND_API_KEY=re_your_resend_api_key_here
FROM_EMAIL=onboarding@resend.dev
TO_EMAIL=you@example.com
